NODE_ENV=development
PORT=4310
WEB_ORIGIN=http://127.0.0.1:4173
DEMO_ORIGIN=http://127.0.0.1:4312
DATABASE_URL=.premortem/premortem.db
ARTIFACTS_DIR=.premortem/artifacts
ALLOW_PRIVATE_TARGETS=false
ALLOW_DEMO_TARGET=true
PREMORTEM_DEV_USER_ID=dev-user
AI_PROVIDER=deterministic
# To enable AI-generated personas and the constrained generic browser agent:
# AI_PROVIDER=openai
# OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.4-mini
AI_TIMEOUT_MS=15000

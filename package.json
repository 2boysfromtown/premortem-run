{
  "name": "premortem",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.7.0",
  "engines": {
    "node": ">=20.19.0"
  },
  "scripts": {
    "dev": "concurrently -k -n demo,api,worker,web -c yellow,cyan,magenta,green \"pnpm dev:demo\" \"pnpm dev:api\" \"pnpm dev:worker\" \"pnpm dev:web\"",
    "dev:web": "vite --config apps/web/vite.config.ts",
    "dev:api": "tsx watch apps/web/server.ts",
    "dev:worker": "tsx watch apps/worker/index.ts",
    "dev:demo": "tsx watch apps/demo-target/server.ts",
    "start:api": "tsx apps/web/server.ts",
    "start:worker": "tsx apps/worker/index.ts",
    "start:demo": "tsx apps/demo-target/server.ts",
    "start:local": "pnpm build:web && pnpm db:migrate && node scripts/run-local.mjs",
    "start:container": "pnpm db:migrate && node scripts/run-local.mjs --no-open",
    "mcp": "tsx apps/mcp/index.ts",
    "db:migrate": "tsx packages/database/src/migrate.ts",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:browser": "vitest run packages/browser-agent",
    "test:e2e": "playwright test",
    "build": "pnpm build:web && tsc -p tsconfig.build.json",
    "build:web": "vite build --config apps/web/vite.config.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "1.29.0",
    "better-sqlite3": "12.11.1",
    "dotenv": "^17.4.2",
    "drizzle-orm": "0.45.2",
    "express": "5.2.1",
    "openai": "^6.46.0",
    "playwright": "1.61.1",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.2",
    "@playwright/test": "1.61.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/express": "5.0.6",
    "@types/node": "24.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "6.0.3",
    "@vitest/coverage-v8": "4.1.10",
    "concurrently": "10.0.3",
    "drizzle-kit": "0.31.10",
    "eslint": "9.39.2",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.5.2",
    "prettier": "3.8.2",
    "tsx": "4.23.0",
    "typescript": "5.9.3",
    "typescript-eslint": "8.53.1",
    "vite": "8.1.4",
    "vitest": "4.1.10"
  }
}
